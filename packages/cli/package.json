{
  "name": "openmuncher",
  "version": "1.0.0",
  "description": "A deliberate AI token-burning desktop app + CLI",
  "type": "module",
  "bin": { "openmuncher": "dist/index.js" },
  "main": "dist/index.js",
  "files": ["dist", "desktop"],
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "start:desktop": "electron desktop/main/index.js"
  },
  "dependencies": {
    "@anthropic-ai/tokenizer": "^0.0.4",
    "electron": "^33.0.0",
    "tiktoken": "^1.0.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@openmuncher/shared": "*",
    "@types/prompts": "^2.4.0",
    "tsup": "^8.0.0"
  }
}
